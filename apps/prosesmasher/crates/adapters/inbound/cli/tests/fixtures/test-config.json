{
  "locale": "en",
  "quality": {
    "lexical": {
      "prohibitedTerms": {
        "defaults": false,
        "add": ["actually", "leverage"],
        "remove": []
      }
    },
    "heuristics": {
      "exclamationDensity": { "maxPerParagraph": 1 },
      "hedgeStacking": { "maxPerSentence": 2 }
    },
    "flow": {
      "paragraphLength": { "maxSentences": 5 },
      "wordRepetition": {
        "max": 5,
        "excludedTerms": {
          "defaults": false,
          "add": ["the", "a", "is", "in", "to", "and", "of", "for"],
          "remove": []
        }
      }
    },
    "readability": {
      "avgSentenceLengthMax": 30
    }
  },
  "documentPolicy": {
    "wordCount": { "min": 10, "max": 500 },
    "headingHierarchy": { "enabled": true },
    "sentenceCaseHeadings": { "enabled": true },
    "codeFences": { "allowed": false }
  }
}
