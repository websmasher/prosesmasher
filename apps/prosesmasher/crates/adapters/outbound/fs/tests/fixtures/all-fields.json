{
  "locale": "de",
  "terms": {
    "bannedWords": ["actually", "basically", "literally"],
    "bannedPhrases": ["let's dive in", "at the end of the day"],
    "genderedTerms": ["mama", "chairman"],
    "forbiddenTerms": ["synergy", "paradigm"],
    "raceTerms": ["exotic"],
    "hedgeWords": ["might", "perhaps", "possibly"],
    "simplicityPairs": [["utilize", "use"], ["implement", "do"], ["facilitate", "help"]],
    "negationSignals": ["not", "isn't", "won't"],
    "reframeSignals": ["it's", "that's", "here's"],
    "llmOpeners": ["the interesting part is", "it's worth noting"],
    "affirmationClosers": ["and that's the key", "and that matters"],
    "summativePatterns": ["and that's what makes", "this is why"],
    "falseQuestionPatterns": ["isn't that what", "don't you think"],
    "humbleBraggerPhrases": ["in my experience", "I've been fortunate"],
    "jargonFakerPhrases": ["debugging your", "optimizing for"],
    "stopWords": ["the", "a", "is", "in", "to", "and", "of", "for"]
  },
  "thresholds": {
    "wordCount": { "min": 650, "max": 1000 },
    "h2Count": { "min": 2, "max": 6 },
    "h3Min": 1,
    "boldMin": 3,
    "maxParagraphSentences": 4,
    "maxExclamationsPerParagraph": 1,
    "maxHedgesPerSentence": 2,
    "fleschKincaidMin": 50.0,
    "gunningFogMax": 14.0,
    "avgSentenceLengthMax": 25,
    "wordRepetitionMax": 5,
    "colemanLiauMax": 12.5
  }
}
