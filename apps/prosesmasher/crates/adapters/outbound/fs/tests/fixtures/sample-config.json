{
  "locale": "en",
  "quality": {
    "lexical": {
      "prohibitedTerms": {
        "defaults": false,
        "add": ["actually", "leverage", "let's dive in", "mama"],
        "remove": []
      },
      "simplicityPairs": {
        "defaults": false,
        "add": [["utilize", "use"], ["implement", "do"]],
        "remove": []
      }
    },
    "heuristics": {
      "paragraphLength": { "maxSentences": 4 },
      "exclamationDensity": { "maxPerParagraph": 1 },
      "hedgeStacking": { "maxPerSentence": 1 },
      "wordRepetition": {
        "max": 5,
        "excludedTerms": {
          "defaults": false,
          "add": ["the", "a", "is", "in", "to", "and"],
          "remove": []
        }
      },
      "readability": {
        "fleschKincaidMin": 50.0,
        "gunningFogMax": 14.0,
        "avgSentenceLengthMax": 25
      }
    }
  },
  "documentPolicy": {
    "wordCount": { "min": 650, "max": 1000 },
    "headingCounts": {
      "h2": { "min": 2, "max": 6 },
      "h3Min": 0
    },
    "boldDensity": { "min": 3 }
  }
}
