{
  "locale": "en",
  "quality": {
    "heuristics": {
      "paragraphLength": { "maxSentences": 3 },
      "exclamationDensity": { "maxPerParagraph": 0 },
      "hedgeStacking": { "maxPerSentence": 0 },
      "wordRepetition": { "max": 4 },
      "readability": {
        "fleschKincaidMin": 58.0,
        "gunningFogMax": 12.0,
        "avgSentenceLengthMax": 18,
        "colemanLiauMax": 11.0
      }
    }
  },
  "documentPolicy": {
    "wordCount": { "min": 120, "max": 700 },
    "headingCounts": {
      "h2": { "min": 1, "max": 5 },
      "h3Min": 0
    },
    "headingHierarchy": { "enabled": true }
  }
}
