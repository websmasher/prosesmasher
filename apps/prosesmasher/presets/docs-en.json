  "thresholds": {
    "wordCount": { "min": 200, "max": 1800 },
    "h2Count": { "min": 1, "max": 10 },
    "h3Min": 1,
    "boldMin": 1,
    "maxParagraphSentences": 3,
    "maxExclamationsPerParagraph": 0,
    "maxHedgesPerSentence": 1,
    "fleschKincaidMin": 45.0,
