{
  "locale": "en",
  "quality": {
    "lexical": {
      "prohibitedTerms": {
        "defaults": false,
        "add": [
          "actually",
          "leverage",
          "seamless",
          "transformative",
          "unlock",
          "elevate",
          "delve",
          "let's dive in",
          "in today's fast-paced world",
          "the key takeaway is",
          "in conclusion"
        ],
        "remove": []
      },
      "simplicityPairs": {
        "defaults": false,
        "add": [
          ["utilize", "use"],
          ["facilitate", "help"],
          ["commence", "start"]
        ],
        "remove": []
      },
      "requiredTerms": []
    },
    "heuristics": {
      "paragraphLength": { "maxSentences": 3 },
      "exclamationDensity": { "maxPerParagraph": 0 },
      "hedgeStacking": { "maxPerSentence": 1 },
      "wordRepetition": {
        "max": 8,
        "excludedTerms": {
          "defaults": false,
          "add": ["the", "a", "an", "is", "in", "to", "and", "of", "for", "that"],
          "remove": []
        }
      },
      "readability": {
        "fleschKincaidMin": 45.0,
        "gunningFogMax": 15.0,
        "avgSentenceLengthMax": 24,
        "colemanLiauMax": 13.0
      }
    }
  },
  "documentPolicy": {
    "wordCount": { "min": 200, "max": 1800 },
    "headingCounts": {
      "h2": { "min": 1, "max": 10 },
      "h3Min": 1
    },
    "boldDensity": { "min": 1 }
  }
}
