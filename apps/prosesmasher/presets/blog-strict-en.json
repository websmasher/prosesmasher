{
  "locale": "en",
  "quality": {
    "lexical": {
      "prohibitedTerms": {
        "defaults": false,
        "add": [
          "actually",
          "leverage",
          "robust",
          "seamless",
          "transformative",
          "unlock",
          "elevate",
          "delve",
          "realm",
          "tapestry",
          "journey",
          "landscape",
          "let's dive in",
          "in today's fast-paced world",
          "at the end of the day",
          "it's important to note",
          "the key takeaway is",
          "in conclusion",
          "when it comes to",
          "one thing is clear"
        ],
        "remove": []
      },
      "simplicityPairs": {
        "defaults": false,
        "add": [
          ["utilize", "use"],
          ["implement", "do"],
          ["facilitate", "help"],
          ["numerous", "many"],
          ["commence", "start"],
          ["optimize", "improve"]
        ],
        "remove": []
      },
      "requiredTerms": []
    },
    "heuristics": {
      "paragraphLength": { "maxSentences": 4 },
      "exclamationDensity": { "maxPerParagraph": 1 },
      "hedgeStacking": { "maxPerSentence": 1 },
      "wordRepetition": {
        "max": 5,
        "excludedTerms": {
          "defaults": false,
          "add": ["the", "a", "an", "is", "in", "to", "and", "of", "for", "that"],
          "remove": []
        }
      },
      "readability": {
        "fleschKincaidMin": 52.0,
        "gunningFogMax": 13.5,
        "avgSentenceLengthMax": 21,
        "colemanLiauMax": 12.0
      }
    }
  },
  "documentPolicy": {
    "wordCount": { "min": 650, "max": 1300 },
    "headingCounts": {
      "h2": { "min": 2, "max": 6 },
      "h3Min": 0
    },
    "boldDensity": { "min": 3 }
  }
}
