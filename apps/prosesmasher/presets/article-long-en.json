{
  "locale": "en",
  "quality": {
    "heuristics": {
      "paragraphLength": { "maxSentences": 5 },
      "readability": {
        "fleschKincaidMin": 45.0,
        "gunningFogMax": 15.0,
        "avgSentenceLengthMax": 24,
        "colemanLiauMax": 13.0
      }
    }
  },
  "documentPolicy": {
    "wordCount": { "min": 1600, "max": 2500 },
    "headingCounts": {
      "h2": { "min": 5, "max": 9 },
      "h3Min": 2
    },
    "headingHierarchy": { "enabled": true }
  }
}
