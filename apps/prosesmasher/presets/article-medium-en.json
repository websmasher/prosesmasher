{
  "locale": "en",
  "quality": {
    "heuristics": {
      "paragraphLength": { "maxSentences": 4 },
      "readability": {
        "avgSentenceLengthMax": 23
      }
    }
  },
  "documentPolicy": {
    "wordCount": { "min": 1000, "max": 1800 },
    "headingCounts": {
      "h2": { "min": 3, "max": 7 },
      "h3Min": 1
    },
    "headingHierarchy": { "enabled": true }
  }
}
